// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  STARTER
  PRO
  GROWTH
  BUSINESS
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum Platform {
  INSTAGRAM
  YOUTUBE
  TIKTOK
  TWITTER
  LINKEDIN
  FACEBOOK
  SNAPCHAT
}

enum MediaType {
  IMAGE
  VIDEO
  CAROUSEL
  TEXT
  REEL
  SHORT
  STORY
}

enum AiRequestType {
  CAPTION
  HASHTAGS
  VIDEO_SCRIPT
  IMAGE
  CHATBOT
  BEST_TIME
}

enum DealStatus {
  PENDING
  NEGOTIATING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  POST_PUBLISH
  POST_SCHEDULE
  EMAIL_SEND
  ANALYTICS_SYNC
  MEDIA_PROCESS
}

enum CommerceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductType {
  COURSE
  DIGITAL
  TEMPLATE
  EBOOK
  COACHING
}

enum CommerceItemType {
  PRODUCT
  COURSE
}

enum PurchaseStatus {
  PENDING
  PAID
  FULFILLED
  FAILED
  REFUNDED
  CANCELLED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String
  handle              String?  @unique  // e.g. techmaster436 — public store URL
  avatarUrl           String?
  password            String?
  provider            String   @default("email")
  role                Role     @default(USER)
  plan                Plan     @default(FREE)
  niche               String?
  bio                 String?
  website             String?
  socialLinks         Json?    // { instagram, youtube, tiktok, twitter }
  razorpayAccountId   String?  // For Razorpay Route split payments
  onboardingCompleted Boolean  @default(false)
  isVerified          Boolean  @default(false)
  isActive            Boolean  @default(true)
  timezone            String   @default("UTC")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  posts          Post[]
  socialAccounts SocialAccount[]
  analytics      Analytics[]
  aiRequests     AiRequest[]
  subscription   Subscription?
  notifications  Notification[]
  refreshTokens  RefreshToken[]
  activityLogs   ActivityLog[]
  invoices       Invoice[]
  brandDeals     BrandDeal[]
  mediaFiles     MediaFile[]
  scheduledJobs  ScheduledJob[]
  videoMetadata  VideoMetadata[]
  seoAnalyses    SeoAnalysis[]
  ownedStore     Store?
  createdProducts Product[]          @relation("CreatorProducts")
  createdCourses  Course[]           @relation("CreatorCourses")
  sales           CommercePurchase[] @relation("CreatorSales")
  buyerPurchases  CommercePurchase[] @relation("BuyerPurchases")
  productAccesses ProductAccess[]
  courseEnrollments CourseEnrollment[]
  streak            UserStreak?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model SocialAccount {
  id                  String    @id @default(cuid())
  userId              String
  platform            Platform
  handle              String    @default("")
  displayName         String    @default("")
  platformUserId      String?
  // Tokens stored AES-256-GCM encrypted — never exposed in API responses
  accessToken         String?
  refreshToken        String?
  tokenExpiresAt      DateTime?
  avatarUrl           String?
  followersCount      Int       @default(0)
  followingCount      Int       @default(0)
  postsCount          Int       @default(0)
  isActive            Boolean   @default(true)
  // OAuth scopes granted by user
  scopes              String[]  @default([])
  // Set to true when token expires so UI shows "reconnect" prompt
  reconnectRequired   Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts PostAccount[]

  // Multi-account: one row per (user, platform, platformUserId) combo
  @@unique([userId, platform, platformUserId])
  @@map("social_accounts")
}

model Post {
  id                String     @id @default(cuid())
  userId            String
  title             String?
  caption           String
  mediaUrls         String[]
  mediaType         MediaType  @default(TEXT)
  platforms         Platform[]
  status            PostStatus @default(DRAFT)
  scheduledAt       DateTime?
  publishedAt       DateTime?
  publishResults    Json?
  aiGenerated       Boolean    @default(false)
  viralScore        Float      @default(0)
  hashtags          String[]
  location          String?
  attachedProductId String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachedProduct Product?        @relation(fields: [attachedProductId], references: [id], onDelete: SetNull)
  analytics       Analytics[]
  accounts        PostAccount[]
  videoMetadata   VideoMetadata[]

  @@map("posts")
}

model PostAccount {
  id              String     @id @default(cuid())
  postId          String
  socialAccountId String
  status          PostStatus @default(DRAFT)
  publishedUrl    String?
  error           String?
  publishedAt     DateTime?

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@map("post_accounts")
}

model Analytics {
  id          String   @id @default(cuid())
  userId      String
  postId      String?
  platform    Platform
  metricName  String
  metricValue Float    @default(0)
  createdAt   DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@map("analytics")
}

model AiRequest {
  id          String        @id @default(cuid())
  userId      String
  requestType AiRequestType
  prompt      String
  result      String?
  tokensUsed  Int           @default(0)
  model       String        @default("gpt-4o")
  cost        Float         @default(0)
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_requests")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 Plan      @default(FREE)
  status               String    @default("ACTIVE")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id              String    @id @default(cuid())
  userId          String
  subscriptionId  String?
  amount          Int       @default(0)
  currency        String    @default("usd")
  status          String    @default("PAID")
  stripeInvoiceId String?
  invoiceUrl      String?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@map("invoices")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String?
  resourceId String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// ─── Brand Deals (Monetization) ──────────────────────────────────────────────

model BrandDeal {
  id           String     @id @default(cuid())
  userId       String
  brandName    String
  contactEmail String?
  contactName  String?
  platform     Platform?
  dealValue    Float      @default(0)
  currency     String     @default("usd")
  status       DealStatus @default(PENDING)
  deliverables String?
  notes        String?
  startDate    DateTime?
  endDate      DateTime?
  paidAmount   Float      @default(0)
  isPaid       Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("brand_deals")
}

// ─── Media Library (Uploads) ─────────────────────────────────────────────────

model MediaFile {
  id           String   @id @default(cuid())
  userId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  thumbnailUrl String?
  folder       String   @default("general")
  alt          String?
  width        Int?
  height       Int?
  duration     Float?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("media_files")
}

// ─── Scheduled Jobs (Queue) ──────────────────────────────────────────────────

model ScheduledJob {
  id          String    @id @default(cuid())
  userId      String
  type        JobType
  status      JobStatus @default(PENDING)
  payload     Json
  result      Json?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  scheduledAt DateTime
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@map("scheduled_jobs")
}

// ─── Video Metadata (Video Analytics) ────────────────────────────────────────

model VideoMetadata {
  id               String    @id @default(cuid())
  userId           String
  postId           String?
  platform         Platform
  videoUrl         String?
  title            String?
  duration         Float     @default(0)
  views            Int       @default(0)
  likes            Int       @default(0)
  comments         Int       @default(0)
  shares           Int       @default(0)
  watchTime        Float     @default(0)
  avgViewDuration  Float     @default(0)
  retentionRate    Float     @default(0)
  clickThroughRate Float     @default(0)
  impressions      Int       @default(0)
  thumbnailUrl     String?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@map("video_metadata")
}

// ─── SEO Analysis ────────────────────────────────────────────────────────────

model SeoAnalysis {
  id               String    @id @default(cuid())
  userId           String
  url              String
  title            String?
  metaDescription  String?
  keywords         String[]
  score            Float     @default(0)
  issues           Json?
  suggestions      Json?
  headings         Json?
  wordCount        Int       @default(0)
  readabilityScore Float     @default(0)
  lastCrawledAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("seo_analyses")
}

// ─── Commerce / Creator Stores ──────────────────────────────────────────────

model Store {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  bannerUrl   String?
  currency    String   @default("usd")
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products  Product[]
  courses   Course[]
  purchases CommercePurchase[]

  @@map("stores")
}

model Product {
  id               String          @id @default(cuid())
  storeId          String
  creatorId        String
  title            String
  slug             String
  description      String
  shortDescription String?
  type             ProductType     @default(DIGITAL)
  price            Int             // in paise/cents (smallest unit)
  originalPrice    Int?            // for showing discount
  currency         String          @default("usd")
  status           CommerceStatus  @default(DRAFT)
  assetUrl         String
  previewUrl       String?         // free preview file
  coverImageUrl    String?
  stock            Int?            // null = unlimited, 0 = out of stock
  tags             String[]
  totalSales       Int             @default(0)
  totalRevenue     Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  publishedAt      DateTime?

  store         Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  creator       User                   @relation("CreatorProducts", fields: [creatorId], references: [id], onDelete: Cascade)
  purchaseItems CommercePurchaseItem[]
  accesses      ProductAccess[]
  attachedPosts Post[]

  @@unique([storeId, slug])
  @@index([creatorId, status])
  @@map("products")
}

model Course {
  id               String          @id @default(cuid())
  storeId          String
  creatorId        String
  title            String
  slug             String
  description      String
  shortDescription String?
  price            Int
  currency         String          @default("usd")
  status           CommerceStatus  @default(DRAFT)
  coverImageUrl    String?
  introVideoUrl    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  publishedAt      DateTime?

  store         Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  creator       User                   @relation("CreatorCourses", fields: [creatorId], references: [id], onDelete: Cascade)
  lessons       CourseLesson[]
  purchaseItems CommercePurchaseItem[]
  enrollments   CourseEnrollment[]

  @@unique([storeId, slug])
  @@index([creatorId, status])
  @@map("courses")
}

model CourseLesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  slug        String
  description String?
  content     String?
  videoUrl    String?
  resourceUrl String?
  position    Int
  isPreview   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course        Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress CourseLessonProgress[]

  @@unique([courseId, slug])
  @@unique([courseId, position])
  @@map("course_lessons")
}

model CommercePurchase {
  id                     String         @id @default(cuid())
  storeId                String
  creatorId              String
  buyerId                String
  stripeCheckoutSessionId String        @unique
  stripePaymentIntentId  String?
  stripeCustomerId       String?
  razorpayOrderId        String?
  razorpayPayId          String?
  totalAmount            Int
  platformFee            Int            @default(0)  // 5% by default
  sellerAmount           Int            @default(0)  // totalAmount - platformFee
  currency               String         @default("usd")
  status                 PurchaseStatus @default(PENDING)
  fulfilledAt            DateTime?
  refundedAt             DateTime?
  refundReason           String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  store             Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  creator           User                   @relation("CreatorSales", fields: [creatorId], references: [id], onDelete: Cascade)
  buyer             User                   @relation("BuyerPurchases", fields: [buyerId], references: [id], onDelete: Cascade)
  items             CommercePurchaseItem[]
  productAccesses   ProductAccess[]
  courseEnrollments CourseEnrollment[]

  @@index([creatorId, status, createdAt])
  @@index([buyerId, status, createdAt])
  @@map("commerce_purchases")
}

model CommercePurchaseItem {
  id            String           @id @default(cuid())
  purchaseId    String
  itemType      CommerceItemType
  productId     String?
  courseId      String?
  titleSnapshot String
  priceSnapshot Int
  createdAt     DateTime         @default(now())

  purchase CommercePurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  course   Course?          @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([courseId])
  @@map("commerce_purchase_items")
}

model ProductAccess {
  id               String   @id @default(cuid())
  productId        String
  buyerId          String
  purchaseId       String
  grantedAt        DateTime @default(now())
  lastDownloadedAt DateTime?
  downloadCount    Int      @default(0)
  downloadLimit    Int      @default(5)

  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer    User             @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  purchase CommercePurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@unique([productId, buyerId])
  @@map("product_accesses")
}

model CourseEnrollment {
  id             String   @id @default(cuid())
  courseId        String
  buyerId         String
  purchaseId      String
  enrolledAt      DateTime @default(now())
  lastAccessedAt  DateTime?
  progressPercent Float    @default(0)

  course         Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  buyer          User                   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  purchase       CommercePurchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  lessonProgress CourseLessonProgress[]

  @@unique([courseId, buyerId])
  @@map("course_enrollments")
}

model CourseLessonProgress {
  id           String   @id @default(cuid())
  enrollmentId String
  lessonId     String
  completedAt  DateTime?
  lastViewedAt DateTime?

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     CourseLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@map("course_lesson_progress")
}

// ─── Gamification ────────────────────────────────────────────────────────────

model UserStreak {
  id             String   @id @default(cuid())
  userId         String   @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  totalXp        Int      @default(0)
  level          Int      @default(1)
  lastActiveDate DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  badges UserBadge[]

  @@map("user_streaks")
}

model UserBadge {
  id        String   @id @default(cuid())
  streakId  String
  badgeKey  String
  earnedAt  DateTime @default(now())

  streak UserStreak @relation(fields: [streakId], references: [id], onDelete: Cascade)

  @@unique([streakId, badgeKey])
  @@map("user_badges")
}

// ─── Plan Features ───────────────────────────────────────────────────────────

model PlanFeature {
  id                  String  @id @default(cuid())
  plan                Plan    @unique
  maxSocialAccounts   Int     // 3, 5, 10, 25, -1 = unlimited
  maxScheduledPosts   Int     // per month
  aiContentGeneration Boolean @default(false)
  advancedAnalytics   Boolean @default(false)
  teamMembers         Int     @default(1)
  customStorefront    Boolean @default(false)
  prioritySupport     Boolean @default(false)
  platformFeePercent  Float   @default(5.0)  // 5.0 = 5%

  @@map("plan_features")
}
