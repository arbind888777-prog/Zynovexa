# ============================================================
# Zynovexa - Environment Variables
# Copy this to .env and fill in the values
# ============================================================

# ─── Domain (used by docker-compose.prod.yml & nginx) ────────
DOMAIN=yourdomain.com
SSL_EMAIL=admin@yourdomain.com
ENABLE_WWW_DOMAIN=false

# ─── Public Supabase Vars For Web App ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ─── Docker Compose Profiles ──────────────────────────────────
# Leave empty when using Supabase or another external database.
# Set to local-db only if you want the bundled local database container.
COMPOSE_PROFILES=

# ─── Local DB Password (only when COMPOSE_PROFILES=local-db) ──
POSTGRES_PASSWORD=change_this_to_a_strong_password

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Database (Supabase / external database service) ─────────
# Supabase transaction pooler example:
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Optional direct connection for migrations/backups when required.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Server-side Supabase integration for auth exchange and storage.
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your_public_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"
SUPABASE_STORAGE_BUCKET=media

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ─── Gemini (optional AI fallback) ───────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
STABILITY_API_KEY=your-stability-api-key
STABILITY_MODEL=stable-image-core
NANO_BANANA_API_KEY=your-nano-banana-api-key
NANO_BANANA_MODEL=gemini-3.1-flash-image-preview
VEO3_API_KEY=your-veo3-api-key
VEO3_MODEL=veo-3.1-generate-preview

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_FREE_PRICE_ID=price_free
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_BUSINESS_PRICE_ID=price_your_business_price_id

# ─── Email (Nodemailer / SMTP / Resend / Sendgrid) ───────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Zynovexa <noreply@zynovexa.com>"
RESEND_API_KEY=your-resend-api-key
SENDGRID_API_KEY=your-sendgrid-api-key

# ─── Frontend URL ────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://yourdomain.com
API_URL=https://yourdomain.com/api

# ─── Social OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
PINTEREST_APP_ID=your-pinterest-app-id
PINTEREST_APP_SECRET=your-pinterest-app-secret
# Login callback (for Google sign-in)
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback
# YouTube account connect callback (separate from login)
YOUTUBE_CONNECT_CALLBACK_URL=https://yourdomain.com/api/accounts/connect/youtube/callback

# ─── YouTube Data API v3 ─────────────────────────────────────
# Get key: https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3
YOUTUBE_DATA_API_KEY=your-youtube-data-api-key-here

# ─── Token Encryption (AES-256-GCM) ──────────────────────────
# REQUIRED in production. Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here
