{
  "name": "zynovexa",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && npm run start:dev",
    "dev:web": "npm run dev --workspace=@zynovexa/web",
    "supabase:check": "node scripts/check-supabase-setup.cjs",
    "redis:windows:check": "powershell -ExecutionPolicy Bypass -File scripts/check-redis-windows.ps1",
    "build:api": "cd apps/api && npm run build",
    "build:web": "cd apps/web && npm run build",
    "build": "npm run build:api && npm run build:web",
    "docker:dev": "docker-compose up -d",
    "docker:dev:local-db": "docker-compose --profile local-db up -d",
    "docker:dev:full": "docker-compose --profile local-db --profile devtools up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "docker:prod:ps": "docker compose -f docker-compose.prod.yml ps",
    "deploy:hostinger": "bash ./deploy.sh",
    "db:migrate": "cd apps/api && npm run db:migrate",
    "db:migrate:prod": "cd apps/api && npx prisma migrate deploy",
    "db:seed": "cd apps/api && npm run db:seed",
    "db:studio": "cd apps/api && npm run db:studio",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 list",
    "test:api": "cd apps/api && npm test",
    "test:web": "cd apps/web && npm test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
